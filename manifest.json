{
  "manifest_version": 3,
  "name": "Canvascope",
  "version": "10.0.0",
  "minimum_chrome_version": "116",
  "default_locale": "en",
  "description": "Instantly search across your Canvas courses, files, and PDFs, customize your LMS theme, and run academic tasks via slash menu.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    },
    "default_title": "Canvascope"
  },
  "permissions": [
    "storage",
    "unlimitedStorage",
    "activeTab",
    "tabs",
    "alarms",
    "offscreen",
    "scripting",
    "identity",
    "downloads",
    "notifications",
    "sidePanel"
  ],
  "oauth2": {
    "client_id": "961806200943-6deqch1r87uthbarmr7te483u4h7fn9m.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/userinfo.email",
      "https://www.googleapis.com/auth/userinfo.profile",
      "https://www.googleapis.com/auth/calendar.events"
    ]
  },
  "host_permissions": [
    "https://*/*",
    "http://*/*",
    "file:///*",
    "https://*.supabase.co/*",
    "*://*.instructure.com/*",
    "*://*.brightspace.com/*",
    "*://*.d2l.com/*",
    "*://bcourses.berkeley.edu/*",
    "*://bruinlearn.ucla.edu/*",
    "*://canvas.ucsd.edu/*",
    "*://canvas.asu.edu/*",
    "*://canvas.mit.edu/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "*://*.instructure.com/*",
        "*://*.brightspace.com/*",
        "*://*.d2l.com/*",
        "*://bcourses.berkeley.edu/*",
        "*://bruinlearn.ucla.edu/*",
        "*://canvas.ucsd.edu/*",
        "*://canvas.asu.edu/*",
        "*://canvas.mit.edu/*"
      ],
      "js": [
        "lib/supabase.js",
        "lib/skin-themes.js",
        "content.js",
        "canvas-skin.js",
        "academic-tools.js",
        "v8/semantic-matcher.js",
        "slash-overlay.js",
        "slash-commands-pack.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "*://*.instructure.com/*",
        "*://*.brightspace.com/*",
        "*://*.d2l.com/*",
        "*://bcourses.berkeley.edu/*",
        "*://bruinlearn.ucla.edu/*",
        "*://canvas.ucsd.edu/*",
        "*://canvas.asu.edu/*",
        "*://canvas.mit.edu/*"
      ],
      "js": [
        "lib/skin-themes.js",
        "docviewer-skin.js"
      ],
      "all_frames": true,
      "run_at": "document_idle"
    }
  ],
  "background": {
    "service_worker": "background-wrapper.js"
  },
  "side_panel": {
    "default_path": "v8/sidepanel.html"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'none'; base-uri 'none';"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "lib/pdf.worker.min.js",
        "popup.html",
        "icons/*"
      ],
      "matches": [
        "*://*.instructure.com/*",
        "*://*.brightspace.com/*",
        "*://*.d2l.com/*",
        "*://bcourses.berkeley.edu/*",
        "*://bruinlearn.ucla.edu/*",
        "*://canvas.ucsd.edu/*",
        "*://canvas.asu.edu/*",
        "*://canvas.mit.edu/*"
      ]
    }
  ]
}